# --- Pick ONE way to send contact form mail (restart `npm run dev` after saving) ---

# Option A — Resend (recommended, no Gmail App Password)
# 1. https://resend.com → sign up (use poznerron2@gmail.com)
# 2. API Keys → create key → paste below
# 3. With onboarding@resend.dev you can only send TO your signup email (your inbox is the default).
RESEND_API_KEY=
# Optional custom from (after you verify a domain on Resend):
# RESEND_FROM=Portfolio <you@yourdomain.com>

# Option B — Gmail SMTP (Google Account must use 2-Step Verification, then App Password)
# https://myaccount.google.com/apppasswords
# SMTP_USER=poznerron2@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx

# Optional — delivery address (default: poznerron2@gmail.com)
# CONTACT_TO_EMAIL=poznerron2@gmail.com
